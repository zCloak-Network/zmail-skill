{
  "name": "zmail",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start:api": "node dist/src/bin/api.js",
    "start:writer": "node dist/src/bin/writer.js",
    "start:mocks": "node dist/src/bin/mocks.js",
    "dev:api": "tsx src/bin/api.ts",
    "dev:writer": "tsx src/bin/writer.ts",
    "dev:mocks": "tsx src/bin/mocks.ts",
    "gcp-build": "npm run build",
    "test": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "test:unit": "vitest run test/unit --passWithNoTests",
    "test:integration": "vitest run test/integration --passWithNoTests",
    "test:integration:firestore": "bash scripts/test/firestore-integration.sh",
    "test:integration:firestore:cloud": "bash scripts/test/firestore-cloud-integration.sh",
    "test:integration:external": "ZMAIL_LIVE_HTTP_TESTS=1 vitest run test/integration/external.live-adapters.test.ts --passWithNoTests",
    "test:e2e": "vitest run test/e2e --passWithNoTests",
    "test:watch": "vitest",
    "test:services": "firebase emulators:start --config firebase.json --only firestore,pubsub",
    "test:mocks": "tsx scripts/test/mocks.ts",
    "test:stack": "bash scripts/test/start-stack.sh",
    "smoke:ops": "bash scripts/ops/smoke-local.sh",
    "smoke:gcp": "bash scripts/ops/smoke-gcp.sh",
    "beta:quickstart": "npm run build && node scripts/ops/beta-quickstart.mjs",
    "beta:alice-bob": "npm run build && node beta-test/run-alice-bob.mjs",
    "beta:ops": "npm run build && node beta-test/ops.mjs",
    "beta:repeat": "npm run build && node beta-test/repeat.mjs",
    "soak:gcp": "bash scripts/ops/soak-gcp.sh",
    "perf:rep": "npm run build && node dist/scripts/perf/representative-load.js",
    "perf:soak": "npm run build && node dist/scripts/perf/multi-node-soak.js",
    "release:rc:check": "bash scripts/release/rc-check.sh",
    "firestore:deploy": "firebase deploy --project zmail-489111 --only firestore:rules,firestore:indexes",
    "deploy:api": "bash scripts/deploy/deploy-api.sh",
    "deploy:writer": "bash scripts/deploy/deploy-writer.sh",
    "deploy:mocks": "bash scripts/deploy/deploy-mocks.sh",
    "client:install:home": "bash scripts/client/install-home-dev.sh",
    "check": "npm run typecheck && npm run test"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "firebase-tools": "^14.21.0",
    "tsx": "^4.20.5",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  },
  "dependencies": {
    "@dfinity/principal": "^3.4.3",
    "@google-cloud/firestore": "^7.11.6",
    "@google-cloud/pubsub": "^4.11.0",
    "@noble/curves": "^2.0.1",
    "google-auth-library": "^9.15.1"
  }
}
